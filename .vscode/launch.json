{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DAPlink",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/debug/STM32F407_Template.elf",
            "request": "launch",
            "type": "cortex-debug",
            "device": "STM32F407VE",
            "svdFile": "${workspaceFolder}/../stm32f407-gcc-framework/STM32F407.svd",
            "servertype": "openocd",
            "configFiles": [
                "openocd_dap.cfg"
            ],
            "preLaunchTask": "Build Debug",
            "runToEntryPoint": "main",
            "overrideLaunchCommands": [
                "monitor reset init",
                "load",
                "monitor reset init"
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "STLink",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/debug/STM32F407_Template.elf",
            "request": "launch",
