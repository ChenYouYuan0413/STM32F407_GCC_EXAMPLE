{
    "configurations": [
        {
            "name": "STM32F407 (ARM GCC)",
            "includePath": [
                "${workspaceFolder}/../stm32f407-gcc-framework/CORE",
                "${workspaceFolder}/../stm32f407-gcc-framework/FWLIB/inc",
                "${workspaceFolder}/USER/Template/src"
            ],
            "defines": [
                "STM32F40_41xxx",
                "USE_STDPERIPH_DRIVER",
                "HSE_VALUE=8000000U",
                "__FPU_PRESENT=1",
                "__FPU_USED=1"
            ],
            "compilerPath": "/opt/homebrew/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-arm"
        }
    ],
    "version": 4
}
